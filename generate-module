#!/usr/bin/env python3
"""
generate-module: Generate JAGS module code from templates and JSON config.

Usage: ./generate-module models/sdt.jnnx/
"""

import json
import os
import sys
from pathlib import Path


def find_files(jnnx_dir):
    """Find required files in .jnnx directory."""
    jnnx_path = Path(jnnx_dir)
    if not jnnx_path.exists():
        print(f"Error: Directory {jnnx_dir} does not exist")
        sys.exit(1)
    
    if not jnnx_path.name.endswith('.jnnx'):
        print(f"Error: Directory {jnnx_dir} does not end with .jnnx")
        sys.exit(1)
    
    # Find JSON file
    json_files = list(jnnx_path.glob("*.json"))
    if not json_files:
        print(f"Error: No JSON file found in {jnnx_dir}")
        sys.exit(1)
    json_file = json_files[0]
    
    # Find ONNX file
    onnx_files = list(jnnx_path.glob("*.onnx"))
    if not onnx_files:
        print(f"Error: No ONNX file found in {jnnx_dir}")
        sys.exit(1)
    onnx_file = onnx_files[0]
    
    # Find PTH file
    pth_files = list(jnnx_path.glob("*.pth"))
    if not pth_files:
        print(f"Error: No PTH file found in {jnnx_dir}")
        sys.exit(1)
    pth_file = pth_files[0]
    
    return json_file, onnx_file, pth_file


def load_config(json_file):
    """Load JSON configuration."""
    try:
        content = json_file.read_text().strip()
        if not content:
            print(f"Error: JSON file {json_file} is empty")
            sys.exit(1)
        return json.loads(content)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON in {json_file}: {e}")
        sys.exit(1)


def format_array(arr):
    """Format array for C++ code."""
    if isinstance(arr, str):
        # Handle string representations like "[-Inf, -Inf]"
        arr = arr.replace('Inf', '1e308').replace('-Inf', '-1e308')
        arr = json.loads(arr)
    return '{' + ', '.join(str(x) for x in arr) + '}'


def generate_module_code(config, onnx_file, pth_file, output_dir):
    """Generate module C++ code from template."""
    template_file = Path(__file__).parent / 'templates' / 'module.cc.template'
    
    if not template_file.exists():
        print(f"Error: Template file {template_file} not found")
        sys.exit(1)
    
    template = template_file.read_text()
    
    # Prepare replacements
    module_name = config.get('module_name', 'unnamed_module')
    function_name = config.get('jags_function_name', 'unnamed_function')
    function_class = function_name.upper() + '_Function'
    module_class = module_name.upper() + '_Module'
    
    input_dim = config.get('input_dimensions', 1)
    output_dim = config.get('output_dimensions', 1)
    
    input_min = config.get('input_limits_min', [])
    input_max = config.get('input_limits_max', [])
    output_min = config.get('output_limits_min', [])
    output_max = config.get('output_limits_max', [])
    
    banner = config.get('banner_string', f'Loading {module_name}')
    
    replacements = {
        '{{MODULE_NAME}}': module_name,
        '{{FUNCTION_NAME}}': function_name,
        '{{FUNCTION_CLASS}}': function_class,
        '{{MODULE_CLASS}}': module_class,
        '{{INPUT_DIM}}': str(input_dim),
        '{{OUTPUT_DIM}}': str(output_dim),
        '{{ONNX_PATH}}': str(onnx_file.absolute()),
        '{{PTH_PATH}}': str(pth_file.absolute()),
        '{{INPUT_MIN}}': format_array(input_min),
        '{{INPUT_MAX}}': format_array(input_max),
        '{{OUTPUT_MIN}}': format_array(output_min),
        '{{OUTPUT_MAX}}': format_array(output_max),
        '{{BANNER_STRING}}': banner
    }
    
    # Apply replacements
    code = template
    for placeholder, value in replacements.items():
        code = code.replace(placeholder, value)
    
    # Write output
    output_file = output_dir / f'{module_name}.cc'
    output_file.write_text(code)
    print(f"Generated: {output_file}")
    
    return output_file


def generate_makefile(config, output_dir):
    """Generate Makefile from template."""
    template_file = Path(__file__).parent / 'templates' / 'Makefile.template'
    
    if not template_file.exists():
        print(f"Error: Template file {template_file} not found")
        sys.exit(1)
    
    template = template_file.read_text()
    
    # Prepare replacements
    module_name = config.get('module_name', 'unnamed_module')
    install_dir = config.get('installation_directory', '/usr/local/lib/JAGS/modules-4/')
    
    replacements = {
        '{{MODULE_NAME}}': module_name,
        '{{INSTALL_DIR}}': install_dir
    }
    
    # Apply replacements
    makefile = template
    for placeholder, value in replacements.items():
        makefile = makefile.replace(placeholder, value)
    
    # Write output
    output_file = output_dir / 'Makefile'
    output_file.write_text(makefile)
    print(f"Generated: {output_file}")
    
    return output_file


def main():
    if len(sys.argv) != 2:
        print("Usage: ./generate-module <jnnx-directory>")
        print("Example: ./generate-module models/sdt.jnnx/")
        sys.exit(1)
    
    jnnx_dir = sys.argv[1]
    jnnx_path = Path(jnnx_dir)
    
    print(f"Generating JAGS module from: {jnnx_dir}")
    print("=" * 60)
    
    # Find required files
    json_file, onnx_file, pth_file = find_files(jnnx_dir)
    print(f"Found files:")
    print(f"  JSON: {json_file}")
    print(f"  ONNX: {onnx_file}")
    print(f"  PTH:  {pth_file}")
    print()
    
    # Load configuration
    config = load_config(json_file)
    print(f"Configuration loaded")
    print()
    
    # Create output directory
    output_dir = jnnx_path / 'build'
    output_dir.mkdir(exist_ok=True)
    print(f"Output directory: {output_dir}")
    print()
    
    # Generate module code
    print("Generating module code...")
    module_file = generate_module_code(config, onnx_file, pth_file, output_dir)
    print()
    
    # Generate Makefile
    print("Generating Makefile...")
    makefile = generate_makefile(config, output_dir)
    print()
    
    print("=" * 60)
    print("Module generation complete!")
    print()
    print("To compile and install:")
    print(f"  cd {output_dir}")
    print("  make")
    print("  sudo make install")


if __name__ == "__main__":
    main()

