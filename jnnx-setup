#!/usr/bin/env python3
"""
jnnx-setup: Interface to read and edit JSON control files for JAGS neural network modules.

Usage: ./jnnx-setup models/sdt.jnnx/
"""

import json
import os
import sys
from pathlib import Path


def find_json_file(jnnx_dir):
    """Find the JSON control file in a .jnnx directory."""
    jnnx_path = Path(jnnx_dir)
    if not jnnx_path.exists():
        print(f"Error: Directory {jnnx_dir} does not exist")
        sys.exit(1)
    
    if not jnnx_path.name.endswith('.jnnx'):
        print(f"Error: Directory {jnnx_dir} does not end with .jnnx")
        sys.exit(1)
    
    # Find JSON file - look for any .json file in the directory
    json_files = list(jnnx_path.glob("*.json"))
    
    if not json_files:
        print(f"Error: No JSON file found in {jnnx_dir}")
        sys.exit(1)
    
    if len(json_files) > 1:
        print(f"Warning: Multiple JSON files found: {json_files}")
        print(f"Using: {json_files[0]}")
    
    return json_files[0]


def load_json_config(json_file):
    """Load JSON configuration, return empty dict if file is empty."""
    try:
        content = json_file.read_text().strip()
        if not content:
            return {}
        return json.loads(content)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON in {json_file}: {e}")
        sys.exit(1)


def save_json_config(json_file, config):
    """Save JSON configuration to file."""
    with open(json_file, 'w') as f:
        json.dump(config, f, indent=2)


def display_config(config):
    """Display current configuration with field clipping."""
    print("\nCurrent configuration:")
    print("=" * 50)
    
    if not config:
        print("(Empty configuration)")
        return
    
    for key, value in config.items():
        if isinstance(value, str) and len(value) > 60:
            display_value = value[:57] + "..."
        elif isinstance(value, list) and len(str(value)) > 60:
            display_value = str(value)[:57] + "..."
        else:
            display_value = value
        
        print(f"{key:20}: {display_value}")


def get_field_value(field_name, current_value=None):
    """Get new value for a field from user input."""
    if current_value is not None:
        print(f"\nCurrent value for '{field_name}': {current_value}")
    
    print(f"Enter new value for '{field_name}' (or press Enter to keep current):")
    new_value = input().strip()
    
    if not new_value and current_value is not None:
        return current_value
    
    # Try to parse as JSON for complex types
    if new_value.startswith('[') or new_value.startswith('{'):
        try:
            return json.loads(new_value)
        except json.JSONDecodeError:
            print("Warning: Invalid JSON format, treating as string")
            return new_value
    
    # Try to parse as number
    try:
        if '.' in new_value:
            return float(new_value)
        else:
            return int(new_value)
    except ValueError:
        return new_value


def edit_config(config):
    """Interactive configuration editing."""
    if not config:
        print("\nNo existing configuration. Creating new configuration.")
        config = {}
    
    fields = [
        "input_dimensions",
        "output_dimensions", 
        "input_limits_min",
        "input_limits_max",
        "output_limits_min",
        "output_limits_max",
        "jags_function_name",
        "module_name",
        "banner_string",
        "installation_directory"
    ]
    
    while True:
        print("\n" + "=" * 50)
        print("Available fields to edit:")
        for i, field in enumerate(fields, 1):
            current = config.get(field, "(not set)")
            if isinstance(current, str) and len(current) > 40:
                current = current[:37] + "..."
            print(f"{i:2}. {field:20}: {current}")
        
        print(f"{len(fields)+1:2}. Save and exit")
        print(f"{len(fields)+2:2}. Exit without saving")
        
        try:
            choice = int(input("\nSelect field to edit (number): "))
        except ValueError:
            print("Invalid input. Please enter a number.")
            continue
        
        if choice == len(fields) + 1:
            return config
        elif choice == len(fields) + 2:
            return None
        elif 1 <= choice <= len(fields):
            field_name = fields[choice - 1]
            current_value = config.get(field_name)
            new_value = get_field_value(field_name, current_value)
            config[field_name] = new_value
            print(f"Updated '{field_name}' to: {new_value}")
        else:
            print("Invalid choice. Please try again.")


def main():
    if len(sys.argv) != 2:
        print("Usage: ./jnnx-setup <jnnx-directory>")
        print("Example: ./jnnx-setup models/sdt.jnnx/")
        sys.exit(1)
    
    jnnx_dir = sys.argv[1]
    json_file = find_json_file(jnnx_dir)
    
    print(f"Found JSON file: {json_file}")
    
    # Load current configuration
    config = load_json_config(json_file)
    
    # Display current configuration
    display_config(config)
    
    # Edit configuration
    new_config = edit_config(config)
    
    if new_config is not None:
        save_json_config(json_file, new_config)
        print(f"\nConfiguration saved to {json_file}")
    else:
        print("\nExiting without saving changes.")


if __name__ == "__main__":
    main()
